# Example environment variables for running the Cyber project
# Copy to .env and edit as needed. Do NOT commit .env to source control.

# Flask port
PORT=5001

# Dataset path override (optional)
# CYBER_DATASET_PATH=C:\path\to\data\combined_training.csv

# Burp API (optional)
# BURP_API_URL=
# BURP_API_KEY=

# Risk thresholds (frontend uses these when evaluating risk level server-side)
# RISK_THRESHOLD_HIGH=0.65
# RISK_THRESHOLD_MED=0.5
